#: .\construction_missions.json
msgid "Sky Island Basement Construction"
msgstr "天空岛地下室建造"

#. ~ Description for mission 'Sky Island Basement Construction'
#: .\construction_missions.json
msgid "Construct a basement level on your sky island."
msgstr "在你的天空岛上建造一层地下室。"

#: .\construction_missions.json
msgid "Sky Island Expansion 1"
msgstr "天空岛扩建 1"

#. ~ Description for mission 'Sky Island Expansion 1'
#: .\construction_missions.json
msgid ""
"Expand your basement with cross-shaped corridors and a central room with "
"skylight."
msgstr "以十字形走廊和带天窗的中心房间扩建你的地下室。"

#: .\construction_missions.json
msgid "Sky Island Expansion 2"
msgstr "天空岛扩建 2"

#. ~ Description for mission 'Sky Island Expansion 2'
#: .\construction_missions.json
msgid "Further expand your basement corridors."
msgstr "进一步扩建你的地下室走廊。"

#: .\construction_missions.json
msgid "Sky Island Expansion 3"
msgstr "天空岛扩建 3"

#. ~ Description for mission 'Sky Island Expansion 3'
#: .\construction_missions.json
msgid "Expand your basement with a larger central room."
msgstr "以更大的中心房间扩建你的地下室。"

#: .\construction_missions.json
msgid "Sky Island Expansion 4"
msgstr "天空岛扩建 4"

#. ~ Description for mission 'Sky Island Expansion 4'
#: .\construction_missions.json
msgid "Complete your basement expansion with maximum size."
msgstr "以最大尺寸完成你的地下室扩建。"

